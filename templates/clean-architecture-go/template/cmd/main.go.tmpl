package main

import (
	"log"
	"net"
	nethttp "net/http"

	httptransport "{{ module_path }}/internal/transport/http"
)

func main() {
	transport := "{{ transport }}"

	switch transport {
	case "http":
		addr := ":8080"
		log.Printf("HTTP listening on %s", addr)
		if err := nethttp.ListenAndServe(addr, httptransport.NewRouter()); err != nil {
			log.Fatal(err)
		}

	case "grpc":
		addr := ":50051"
		log.Printf("gRPC transport selected; starting stub listener on %s", addr)

		ln, err := net.Listen("tcp", addr)
		if err != nil {
			log.Fatal(err)
		}
		defer func() { _ = ln.Close() }()

		for {
			conn, err := ln.Accept()
			if err != nil {
				continue
			}
			_ = conn.Close()
		}

	default:
		log.Fatalf("unknown transport %q", transport)
	}
}
